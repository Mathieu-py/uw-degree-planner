# Supabase — local dev (from `pnpm exec supabase status`)
# Copy this file to `.env.local` and fill in the values after `supabase start`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: Google OAuth for the local Supabase Auth server.
# Only needed if you flip `[auth.external.google] enabled = true` in
# supabase/config.toml. See supabase/README.md for the Google Cloud setup.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
